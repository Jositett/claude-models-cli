{
  "name": "claude-models-cli",
  "version": "1.4.0",
  "description": "Cross-platform CLI for managing free AI models with Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cm": "./dist/cli.js",
    "claude-models": "./dist/cli.js"
  },
  "scripts": {
    "prepublishOnly": "bun run build",
    "build": "bun x tsc",
    "build:cli": "bun x tsc",
    "build:lib": "bun x tsc",
    "dev": "bun --watch ./src/cli.ts",
    "start": "bun ./dist/cli.js",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "types": "bun x tsc --noEmit",
    "lint": "bun x tsc --noEmit"
  },
  "keywords": [
    "claude",
    "ai",
    "cli",
    "openrouter",
    "free-models",
    "bun",
    "cross-platform"
  ],
  "author": "Joedroid",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "install.sh",
    "install.ps1"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOURUSERNAME/claude-models-cli.git"
  },
  "bugs": {
    "url": "https://github.com/YOURUSERNAME/claude-models-cli/issues"
  },
  "homepage": "https://github.com/YOURUSERNAME/claude-models-cli#readme",
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
